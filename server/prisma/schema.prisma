// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------
// ENUMS (Перечисления)
// ------------------------------------

enum Role {
  OWNER
  MANAGER
  EMPLOYEE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ------------------------------------
// MODELS (Модели)
// ------------------------------------

/// Организация (Для SaaS мультиарендности / Multi-tenancy)
model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique // Название компании в URL (например: my-company)
  createdAt DateTime @default(now())

  users    User[]
  projects Project[]
}

/// Пользователи
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(EMPLOYEE)
  hourlyRate Float?  // Ставка сотрудника

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Связи
  refreshTokens    RefreshToken[]
  managedProjects  Project[]       @relation("ProjectManager")
  assignedProjects Project[]       @relation("ProjectEmployees")
  assignedTasks    Task[]          @relation("TaskAssignee")
  timeEntries      TimeEntry[]
}

/// Refresh-токены для авторизации
model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

/// Проекты
model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("PLANNED") // PLANNED, ACTIVE, COMPLETED, ARCHIVED
  budgetHours Float?   // Бюджет проекта в часах

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Менеджер проекта
  managerId   Int?
  manager     User?    @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)

  // Назначенные сотрудники
  employees   User[]   @relation("ProjectEmployees")

  tasks       Task[]
  timeEntries TimeEntry[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Задачи (Task) — Новая важная сущность!
model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)

  projectId   Int
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId  Int?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  timeEntries TimeEntry[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

/// Записи отработанного времени (Time Tracking)
model TimeEntry {
  id          Int      @id @default(autoincrement())
  hours       Float    // Время в часах (например 1.5)
  description String?  // Что было сделано за это время
  date        DateTime @default(now())
  isApproved  Boolean  @default(false) // Подтверждение менеджером

  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  taskId      Int?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
}
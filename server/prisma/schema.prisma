// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Таблица пользователей в нашей БД

enum Role {
  OWNER
  MANAGER
  EMPLOYEE
}

model User {
  id        Int      @id @default(autoincrement()) 
  email     String   @unique                       
  password  String
  name      String?                                
  createdAt DateTime @default(now())               
  posts     Post[]
  role      Role     @default(EMPLOYEE)
  refreshTokens RefreshToken[]  
                    // Ставка сотрудника (только для просмотра/настройки Owner)
  hourlyRate Float?

  // Связи
  managedProjects  Project[]   @relation("ProjectManager")
  assignedProjects Project[]   @relation("ProjectEmployees")
  timeEntries      TimeEntry[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())

  // Внешний ключ, связывающий пост с автором
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Project {
  id          Int         @id @default(autoincrement())
  title       String
  status      String      @default("PLANNED") // Стадии проекта
  
  // Менеджер проекта
  managerId   Int?
  manager     User?       @relation("ProjectManager", fields: [managerId], references: [id])
  
  // Назначенные сотрудники
  employees   User[]      @relation("ProjectEmployees")
  timeEntries TimeEntry[]
}

model TimeEntry {
  id          Int      @id @default(autoincrement())
  hours       Float
  date        DateTime @default(now())
  isApproved  Boolean  @default(false) // Подтверждение менеджером
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id])
}
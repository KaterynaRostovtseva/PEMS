// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Таблица пользователей в нашей БД

enum Role {
  USER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement()) // Уникальный ID (1, 2, 3...)
  email     String   @unique                       // Email должен быть уникальным
  password  String
  name      String?                                // Имя (необязательное)
  createdAt DateTime @default(now())               // Дата создания
  posts     Post[]
  role      Role     @default(USER)
  refreshTokens RefreshToken[]                     //Связь с токенами
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())

  // Внешний ключ, связывающий пост с автором
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}